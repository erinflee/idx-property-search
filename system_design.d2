
direction: right

U: User
ST: "Short term: session state"
LT: "Long term: vector store"
TE: "Tools: typed async functions"
R: Response
H: "Human-in-the-loop approval"

Channels: {
  WA: WhatsApp
  EM: Email
  WEB: Web
}

OR: OpenClaw runtime {
  O: Orchestrator
  S: Sessions
}

Skills: {
  PS: Property search
  MS: Market stats
  RAG: RAG pipeline
  REC: Recommendation engine
  DE: Draft Emails
}

DB: MySQL databases {
  RP: rets_property
  CS: california_sold
}

# user enters through any channel
U -> Channels.WA
U -> Channels.EM
U -> Channels.WEB

# channels converge to start session
Channels -> OR.S

# orchestrator chooses from skills
OR.S -> OR.O
OR.O -> Skills.PS
OR.O -> Skills.MS
OR.O -> Skills.RAG
OR.O -> Skills.REC
OR.O -> Skills.DE

# memory usage
OR.S -> ST
LT -> Skills.RAG
Skills -> TE
TE -> ST

# data sources
DB.RP -> Skills.PS
DB.CS -> Skills.MS
DB.RP -> Skills.REC
DB.CS -> Skills.REC

# email draft → approval → sent
Skills.DE -> H
H -> Channels.EM

# response back to user
ST -> R
R -> U